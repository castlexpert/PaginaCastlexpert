# Copia este archivo a `.env.local` y pega los valores de la consola de Firebase (Configuración del proyecto → Tus apps).

# Si el sitio estático se sirve en otro dominio que el API Node (Railway), define la URL base del backend para chat/contacto/handoff:
# VITE_PUBLIC_API_URL=https://tu-servicio.up.railway.app

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=

# --- Correo avisos formulario Contáctenos (opcional; si no hay nada, solo se guarda en Postgres) ---
# Opción A — Resend (recomendado): https://resend.com
# RESEND_API_KEY=re_...
# RESEND_FROM=CastleXpert <onboarding@resend.dev>
# Opción B — SMTP (ej. Gmail con contraseña de aplicación)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=tu@gmail.com
# SMTP_PASS=contraseña_de_aplicacion
# SMTP_FROM=CastleXpert <tu@gmail.com>
# Destinatarios del aviso (coma separada)
# CONTACT_NOTIFY_TO=info@castlexpert.com,castlexpertcr@gmail.com
